{
  "type": "module",
  "name": "server",
  "version": "1.0.0",
  "main": "app.ts",
  "scripts": {
    "start": "npm run build:ts && fastify start -l info dist/src/app.js",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "dev": "npm run build:ts && fastify start --ignore-watch=.ts$ -w -l info -P dist/src/app.js",
    "test": "vitest run",
    "test:unit": "vitest run --dir src",
    "test:integration": "vitest run --dir test"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/sensible": "^6.0.0",
    "better-sqlite3": "^11.0.0",
    "fastify-cli": "^7.4.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^24.0.8",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.0.0",
    "fastify-tsconfig": "^3.0.0",
    "typescript": "~5.9.2",
    "vitest": "^3.0.0"
  }
}
